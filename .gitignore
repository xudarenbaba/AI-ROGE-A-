# 依赖与虚拟环境
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# 配置与密钥（勿提交真实 api_key）
config.yaml
config.local.yaml
.env
.env.local

# 数据与模型缓存
data/
models/
*.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# 日志
*.log
logs/

# ── RL 训练产物（各肢目录内，不提交）────────────────────────────────────────
# 检查点 / TensorBoard / 评估
rl/limbs/*/checkpoints/
rl/limbs/*/logs/
# 肢目录内误放的导出副本（正式导出只在 game/resources）
rl/limbs/*/*.onnx
rl/limbs/*/*_meta.json
rl/limbs/*/policy.onnx
rl/limbs/*/meta.json

# ── 游戏部署模型（提交 resources 下的正式导出）──────────────────────────────
# 跟踪：game/resources/limbs/<limb_id>/policy.onnx + meta.json + manifest.json
# 勿在 game/ 根目录再放 onnx
game/*.onnx
